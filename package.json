{
  "name": "quiz-trivia",
  "version": "1.0.5",
  "description": "Local network party quiz game",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "coverage": "nyc npm test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "nyc": {
    "all": true,
    "include": [
      "local-db.js",
      "questions.js",
      "server.js",
      "server/*.js",
      "games/*/server.js"
    ],
    "exclude": [
      "node_modules/**",
      "tests/**",
      "public/**"
    ],
    "reporter": [
      "text",
      "lcov",
      "html"
    ],
    "report-dir": "coverage"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "qrcode": "^1.5.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "nyc": "^18.0.0",
    "puppeteer-core": "^24.37.5"
  }
}
